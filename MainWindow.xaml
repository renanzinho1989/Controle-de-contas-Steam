                            <StackPanel>
                                <TextBlock x:Name="DropModalConditionLabelText" Text="Condicao" Style="{StaticResource LabelText}" Margin="0,0,0,6" />
                                <ComboBox x:Name="DropConditionBox">
                                    <ComboBoxItem x:Name="DropConditionNoneItem" Tag="None" Content="None" Foreground="#8DA4B5" />
                                    <ComboBoxItem x:Name="DropConditionFactoryItem" Tag="Nova de F&#x00E1;brica" Content="Nova de F&#x00E1;brica" Foreground="#39C970" IsSelected="True" />
                                    <ComboBoxItem x:Name="DropConditionMinimalItem" Tag="Pouco Desgastada" Content="Pouco Desgastada" Foreground="#58A6FF" />
                                    <ComboBoxItem x:Name="DropConditionFieldItem" Tag="Testada em Campo" Content="Testada em Campo" Foreground="#E4C25A" />
                                    <ComboBoxItem x:Name="DropConditionWornItem" Tag="Bem Desgastada" Content="Bem Desgastada" Foreground="#F39A32" />
                                    <ComboBoxItem x:Name="DropConditionBattleItem" Tag="Veterana de Guerra" Content="Veterana de Guerra" Foreground="#C981FF" />
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock x:Name="DropModalValueLabelText" Text="Valor (R$)" Style="{StaticResource LabelText}" Margin="0,0,0,6" />
                                <TextBox x:Name="DropValueBox"
                                         Text="0,00"
                                         PreviewTextInput="MoneyTextBox_PreviewTextInput"
                                         DataObject.Pasting="MoneyTextBox_Pasting" />
                            </StackPanel>
                        </Grid>

                        <TextBlock x:Name="DropModalErrorText" Foreground="{StaticResource Red}" FontSize="12" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
                            <Button Style="{StaticResource ModalCancelButton}" Margin="0,0,10,0" Click="CloseDropModalButton_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,8,0" />
                                    <TextBlock x:Name="DropModalCancelButtonText" Text="Cancelar" />
                                </StackPanel>
                            </Button>
                            <Button x:Name="SaveDropButton" Style="{StaticResource ModalActionButton}" MinWidth="160" Click="SaveDropButton_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,8,0" />
                                    <TextBlock x:Name="SaveDropButtonText" Text="Adicionar Drop" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <Grid x:Name="ConfirmOverlay" Grid.ColumnSpan="2" Visibility="Collapsed" Background="#B4030A12">
                <Border Background="{StaticResource Panel}"
                        BorderBrush="#8D2530"
                        BorderThickness="1"
                        CornerRadius="7"
                        Width="430"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Padding="20">
                    <StackPanel>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="42"
                                        Height="42"
                                        Background="#32151C"
                                        BorderBrush="#8D2530"
                                        BorderThickness="1"
                                        CornerRadius="21"
                                        Margin="0,0,14,0">
                                    <TextBlock Text="&#xE74D;"
                                               FontFamily="Segoe MDL2 Assets"
                                               Foreground="{StaticResource Red}"
                                               FontSize="20"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock x:Name="ConfirmTitleText"
                                               Text="Confirmar exclusao"
                                               FontFamily="{StaticResource DisplayFont}"
                                               Foreground="#F7FBFF"
                                               FontSize="22"
                                               FontWeight="SemiBold" />
                                    <TextBlock x:Name="ConfirmSubtitleText" Text="Essa acao nao pode ser desfeita."
                                               Foreground="{StaticResource Muted}"
                                               FontSize="12"
                                               Margin="0,3,0,0" />
                                </StackPanel>
                            </StackPanel>
                            <Button x:Name="CloseConfirmOverlayButton"
                                    Grid.Column="1"
                                    Content="&#xE8BB;"
                                    FontFamily="Segoe MDL2 Assets"
                                    Style="{StaticResource GridIconButton}"
                                    Width="34"
                                    Height="32"
                                    BorderBrush="Transparent"
                                    Click="CloseConfirmDialogButton_Click"
                                    ToolTip="Fechar" />
                        </Grid>

                        <Border Background="#081420"
                                BorderBrush="{StaticResource Line}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="14"
                                Margin="0,0,0,18">
                            <TextBlock x:Name="ConfirmMessageText"
                                       Text="Deseja excluir?"
                                       Foreground="#E9F3FF"
                                       FontSize="14"
                                       TextWrapping="Wrap"
                                       LineHeight="22" />
                        </Border>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Style="{StaticResource ModalCancelButton}"
                                    Margin="0,0,10,0"
                                    Click="CloseConfirmDialogButton_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,8,0" />
                                    <TextBlock x:Name="ConfirmCancelButtonText" Text="Cancelar" />
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource ConfirmDeleteButton}"
                                    Click="ConfirmDeleteButton_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,8,0" />
                                    <TextBlock x:Name="ConfirmDeleteButtonText" Text="Excluir" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
